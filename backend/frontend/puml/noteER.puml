@startuml
' 模块二：作业与笔记
left to right direction
skinparam linetype ortho

entity "课程(class)" as class {
  + id : INT <<PK>>
  --
  class_name : VARCHAR(200)
}

entity "作业(task)" as task {
  + id : INT <<PK>>
  --
  class_id : INT <<FK>>
  title : VARCHAR(200)
  deadline : DATETIME
}

entity "用户(user)" as user {
  + id : INT <<PK>>
  --
  username : VARCHAR(100)
  role : INT
}

entity "笔记(note)" as note {
  + id : INT <<PK>>
  --
  user_id : INT <<FK>>
  task_id : INT <<FK>>
  title : VARCHAR(200)
  vision : TINYINT
}

entity "作业总结(assignment_summary)" as summary {
  + id : BIGINT <<PK>>
  --
  task_id : BIGINT <<FK>>
  summary : LONGTEXT
}

' 关系定义
class "1" -- "n" task : "发布"
task "1" -- "n" note : "被关联（作业笔记）"
task "1" -- "1" summary : "拥有总结"
user "1" -- "n" note : "创作"

note right of note
  note.task_id 关联 task.id，
  表示该笔记的来源作业。
  可为空，表示非作业的自由笔记。
end note
@enduml