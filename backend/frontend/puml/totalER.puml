@startuml
' 完整E-R图
left to right direction
skinparam linetype ortho

' 定义实体
entity "用户(user)" as user {
  + id : INT <<PK>>
  --
  username : VARCHAR(100)
  user_account : VARCHAR(20) <<U1>>
  real_name : VARCHAR(100)
  role : INT
  ... (其他字段)
}

entity "课程(class)" as class {
  + id : INT <<PK>>
  --
  class_name : VARCHAR(200)
  teacher_id : INT <<FK>>
  status : INT
  ... (其他字段)
}

entity "作业(task)" as task {
  + id : INT <<PK>>
  --
  class_id : INT <<FK>>
  title : VARCHAR(200)
  deadline : DATETIME
  ... (其他字段)
}

entity "笔记(note)" as note {
  + id : INT <<PK>>
  --
  title : VARCHAR(200)
  user_id : INT <<FK>>
  task_id : INT <<FK>>
  vision : TINYINT
  ... (其他字段)
}

entity "标签(tag)" as tag {
  + id : INT <<PK>>
  --
  name : VARCHAR(50) <<U1>>
  category : VARCHAR(50)
  ... (其他字段)
}

entity "笔记附件(note_att)" as note_att {
  + id : INT <<PK>>
  --
  note_id : INT <<FK>>
  file_url : VARCHAR(255)
  ... (其他字段)
}

entity "笔记评价(note_comment)" as note_comment {
  + id : INT <<PK>>
  --
  note_id : INT <<FK>> <<U1>>
  teacher_id : INT <<FK>>
  score : INT
  ... (其他字段)
}

entity "笔记互动(note_interaction)" as note_interaction {
  + id : INT <<PK>>
  --
  note_id : INT <<FK>>
  user_id : INT <<FK>>
  type : INT
  ... (其他字段)
}

entity "笔记版本(note_version)" as note_version {
  + id : INT <<PK>>
  --
  note_id : INT <<FK>>
  version : INT
  ... (其他字段)
}

entity "课程参与(class_joined)" as class_joined {
  + id : INT <<PK>>
  --
  class_id : INT <<FK>>
  student_id : INT <<FK>>
  ... (其他字段)
}

entity "作业总结(assignment_summary)" as assignment_summary {
  + id : BIGINT <<PK>>
  --
  task_id : BIGINT <<FK>>
  summary : LONGTEXT
  ... (其他字段)
}

entity "举报(report)" as report {
  + id : INT <<PK>>
  --
  type_id : INT
  user_id : INT <<FK>>
  ... (其他字段)
}

' 关联实体（多对多关系表）
entity "笔记-标签关联(note_tag)" as note_tag {
  + id : INT <<PK>>
  --
  note_id : INT <<FK>>
  tag_id : INT <<FK>>
  <<U1>> (note_id, tag_id)
}

' 定义关系
' 1. 核心关系：用户与课程、笔记
user ||--o{ class : "创建/教授"
user ||--o{ note : "创作"
user ||--o{ class_joined : "参与（学生）"
user ||--o{ note_comment : "评价（教师）"
user ||--o{ note_interaction : "互动"

' 2. 课程、作业、笔记关系链
class ||--o{ task : "发布"
class ||--o{ class_joined : "包含学生"
task ||--o{ note : "关联为（作业笔记）"
task ||--o{ assignment_summary : "拥有总结"

' 3. 笔记的扩展关系
note ||--o{ note_att : "拥有附件"
note ||--o{ note_version : "历史版本"
note ||--o{ note_comment : "获得评价"
note ||--o{ note_interaction : "获得互动"
note ||--o{ note_tag : "拥有标签"
tag ||--o{ note_tag : "被笔记引用"

' 4. 其他关系
user ||--o{ report : "发起"
@enduml