@startuml
' 模块三：笔记扩展功能
left to right direction
skinparam linetype polyline

entity "笔记(note)" as note {
  + id : INT <<PK>>
  --
  title : VARCHAR(200)
  user_id : INT <<FK>>
}

entity "标签(tag)" as tag {
  + id : INT <<PK>>
  --
  name : VARCHAR(50) <<U1>>
  category : VARCHAR(50)
}

entity "笔记-标签关联(note_tag)" as note_tag {
  + id : INT <<PK>>
  --
  note_id : INT <<FK>>
  tag_id : INT <<FK>>
  <<U1>> (note_id, tag_id)
}

entity "笔记评价(note_comment)" as comment {
  + id : INT <<PK>>
  --
  note_id : INT <<FK>> <<U1>>
  teacher_id : INT <<FK>>
  score : INT
}

entity "笔记互动(note_interaction)" as interaction {
  + id : INT <<PK>>
  --
  note_id : INT <<FK>>
  user_id : INT <<FK>>
  type : INT
}

entity "笔记版本(note_version)" as version {
  + id : INT <<PK>>
  --
  note_id : INT <<FK>>
  version : INT
  title : VARCHAR(200)
}

entity "笔记附件(note_att)" as attachment {
  + id : INT <<PK>>
  --
  note_id : INT <<FK>>
  file_url : VARCHAR(255)
}

' 关系定义
note "1" -- "0..n" comment : "获得评价 (1:1 via unique)"
note "1" -- "0..n" interaction : "获得互动"
note "1" -- "0..n" version : "历史版本"
note "1" -- "0..n" attachment : "拥有附件"

note "1" -- "0..n" note_tag : ""
tag "1" -- "0..n" note_tag : ""
note_tag }o--|| note
note_tag }o--|| tag

note right of comment
  note_comment.note_id 有唯一约束，
  确保一篇笔记仅获得一条教师评价。
end note
@enduml