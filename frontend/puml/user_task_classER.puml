@startuml
' 模块一：用户与课程核心
left to right direction
skinparam linetype ortho

entity "用户(user)" as user {
  + id : INT <<PK>>
  --
  username : VARCHAR(100)
  role : INT
  real_name : VARCHAR(100)
}

entity "课程(class)" as class {
  + id : INT <<PK>>
  --
  class_name : VARCHAR(200)
  teacher_id : INT <<FK>>
}

entity "课程参与(class_joined)" as class_joined {
  + id : INT <<PK>>
  --
  class_id : INT <<FK>>
  student_id : INT <<FK>>
  status : INT
}

' 关系定义
user "1" -- "0..n" class : teacher_id = user.id <<作为教师创建>>
user "1" -- "0..n" class_joined : student_id = user.id <<作为学生加入>>
class "1" -- "0..n" class_joined : class_id = class.id <<包含学生>>
note right of class_joined
  该表建立了学生与课程之间的
  多对多参与关系。
end note
@enduml